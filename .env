# Committed defaults — safe, non-secret. Machine-specific overrides go in .env.local
# (gitignored). Remember: every VITE_* value is baked into the client bundle and is
# therefore public — never put real secrets here.

# Backend REST base URL as seen by the browser.
#   empty        = same-origin. In dev, requests go through the Vite proxy
#                  (VITE_DEV_PROXY_TARGET below); in prod, works when the SPA is
#                  served from the backend's own domain.
#   absolute URL = cross-origin requests (e.g. https://tc-screener.com).
VITE_API_BASE_URL=

# Optional explicit WebSocket base. Empty = derived from VITE_API_BASE_URL / origin.
VITE_WS_BASE_URL=

# Dev-only: where the Vite dev server proxies /api and /ws. Read by vite.config.ts,
# not by application code.
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Default/fallback UI locale (en | ru). The *detected* locale (browser language /
# saved choice) overrides this at runtime; this is only the floor / fallbackLng.
VITE_DEFAULT_LOCALE=en
